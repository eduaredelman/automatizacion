                  "    console.log('    plan_price:', c.plan_price);",
                  "    console.log('    bot_intent:', c.bot_intent);",
                  "  }",
                  "  console.log('');",
                  "  console.log('--- WispHub ---');",
                  "  if (rep.wisphub.client_by_phone) {",
                  "    const w = rep.wisphub;",
                  "    console.log('  Cliente en WispHub:', w.client_name);",
                  "    console.log('  ID Servicio:', w.client_id);",
                  "    console.log('  Celular WispHub:', w.client_phone_celular);",
                  "    console.log('  Campos de precio:', JSON.stringify(w.plan_price_fields));",
