                  "console.log('Total:', facturas.length);",
                  "facturas.forEach((f, i) => {",
                  "  const monto = parseFloat(f.total || f.sub_total || f.monto || 0);",
                  "  console.log(`Factura ${i+1}: ID=${f.id_factura || f.id} | Estado=${f.estado} | Monto=S/${monto} | Vence=${f.fecha_vencimiento}`);",
                  "});"
                ]
