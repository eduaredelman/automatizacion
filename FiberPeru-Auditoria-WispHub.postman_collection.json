    {
      "name": "5. CRM - Auditoria completa (backend)",
      "item": [
        {
          "name": "5a. Resumen general de la BD",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "if (r.success) {",
                  "  const s = r.summary;",
                  "  console.log('=== RESUMEN BASE DE DATOS ===');",
                  "  console.log('Conversaciones por estado:', JSON.stringify(s.conversations_by_status));",
                  "  console.log('Clientes por estado servicio:', JSON.stringify(s.clients_by_service_status));",
                  "  console.log('Pagos por estado:', JSON.stringify(s.payments_by_status));",
                  "  console.log('ALERTAS:');",
