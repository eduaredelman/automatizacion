              "host": ["{{WISPHUB_URL}}"],
              "path": ["facturas", ""],
              "query": [
                { "key": "usuario", "value": "{{WISPHUB_USUARIO}}" },
                { "key": "estado", "value": "Pendiente de Pago" },
                { "key": "limit", "value": "50" }
              ]
            },
            "description": "Buscar facturas usando el campo 'usuario' de WispHub (mas confiable que id_servicio)."
          }
        },
        {
          "name": "2c. TODAS las facturas del cliente (todos los estados)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "const facturas = r.results || (Array.isArray(r) ? r : []);",
                  "console.log('=== TODAS LAS FACTURAS ===');",
                  "console.log('Total:', facturas.length);",
                  "",
                  "// Agrupar por estado",
                  "const byEstado = {};",
                  "facturas.forEach(f => {",
                  "  const e = f.estado || 'sin_estado';",
                  "  byEstado[e] = (byEstado[e] || 0) + 1;",
                  "});",
                  "console.log('Por estado:', JSON.stringify(byEstado));",
                  "",
                  "// Montos unicos",
                  "const montos = [...new Set(facturas.map(f => parseFloat(f.total || f.sub_total || f.monto || 0)))];",
                  "console.log('Montos unicos en facturas:', montos.sort((a,b) => a-b));",
                  "",
                  "// Mostrar las 5 mas recientes",
                  "facturas.slice(0,5).forEach((f, i) => {",
                  "  console.log(`[${i+1}] ID=${f.id_factura || f.id} | ${f.estado} | S/${f.total || f.monto} | id_servicio=${f.cliente?.id_servicio || f.id_servicio}`);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Api-Key {{WISPHUB_TOKEN}}" }],
