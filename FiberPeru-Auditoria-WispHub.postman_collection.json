{
  "info": {
    "_postman_id": "fiberperu-wisphub-audit-v1",
    "name": "FiberPeru - Auditoria WispHub CRM",
    "description": "Auditoria completa para detectar vinculaciones incorrectas, montos erroneos y pagos mal asignados entre WispHub y el CRM FiberPeru.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "WISPHUB_URL",    "value": "https://api.wisphub.app/api",             "type": "string" },
    { "key": "WISPHUB_TOKEN",  "value": "Aef4xvDp.KBX6PKTl3qRMRLVj41dZGeys1ZGGOyTz", "type": "string" },
    { "key": "BACKEND_URL",    "value": "http://localhost:3001",                    "type": "string" },
    { "key": "CRM_TOKEN",      "value": "",                                         "type": "string" },
    { "key": "PHONE_AUDIT",    "value": "51XXXXXXXXX",                              "type": "string", "description": "Telefono del cliente a auditar (formato 51XXXXXXXXX)" },
    { "key": "PHONE_9DIGITS",  "value": "XXXXXXXXX",                               "type": "string", "description": "Telefono sin prefijo 51 (9 digitos)" },
    { "key": "WISPHUB_CLIENT_ID", "value": "",                                      "type": "string", "description": "Se llena automaticamente con los tests" },
    { "key": "WISPHUB_USUARIO",   "value": "",                                      "type": "string" },
    { "key": "CONVERSATION_ID",   "value": "",                                      "type": "string", "description": "UUID de la conversacion a auditar" }
  ],
  "item": [

    {
      "name": "0. CRM - Login (obtener token)",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "if (r.token) {",
                  "  pm.collectionVariables.set('CRM_TOKEN', r.token);",
                  "  console.log('Token guardado:', r.token.substring(0,30) + '...');",
                  "} else {",
                  "  console.error('Login fallido:', JSON.stringify(r));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{BACKEND_URL}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@fiberperu.com\",\n  \"password\": \"admin123\"\n}"
            },
            "description": "Obtener JWT token para acceder a los endpoints del CRM. Ajustar email/password segun tu usuario."
          }
        }
      ]
    },

    {
      "name": "1. WispHub - Buscar cliente por telefono",
      "item": [
        {
          "name": "1a. Buscar por celular (sin prefijo 51)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "const results = r.results || (Array.isArray(r) ? r : []);",
                  "console.log('Total resultados:', results.length);",
                  "if (results.length > 0) {",
                  "  const c = results[0];",
                  "  pm.collectionVariables.set('WISPHUB_CLIENT_ID', String(c.id_servicio || c.id || ''));",
                  "  pm.collectionVariables.set('WISPHUB_USUARIO', String(c.usuario || ''));",
                  "  console.log('=== CLIENTE ENCONTRADO ===');",
                  "  console.log('ID Servicio:', c.id_servicio || c.id);",
                  "  console.log('Nombre:', c.nombre || c.nombre_completo);",
                  "  console.log('Celular:', c.celular);",
                  "  console.log('Telefono:', c.telefono);",
                  "  console.log('Movil:', c.movil);",
                  "  console.log('Plan:', c.plan || c.plan_nombre);",
                  "  console.log('Usuario WispHub:', c.usuario);",
                  "  console.log('Estado:', c.estado || c.activo);",
                  "  console.log('Todos los campos:', Object.keys(c).join(', '));",
                  "  console.log('Campos de precio:', {",
                  "    precio_plan: c.precio_plan,",
                  "    monto_plan: c.monto_plan,",
                  "    precio: c.precio,",
                  "    costo: c.costo,",
                  "    valor: c.valor,",
                  "    monto: c.monto",
                  "  });",
                  "  pm.test('Cliente encontrado', () => pm.expect(results.length).to.be.above(0));",
                  "  pm.test('Telefono coincide', () => {",
                  "    const phone9 = pm.collectionVariables.get('PHONE_9DIGITS');",
                  "    const celular = String(c.celular || '').replace(/\\D/g, '');",
                  "    pm.expect(celular).to.include(phone9);",
                  "  });",
                  "} else {",
                  "  console.warn('ADVERTENCIA: No se encontro cliente para este telefono');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Api-Key {{WISPHUB_TOKEN}}" }],
            "url": {
              "raw": "{{WISPHUB_URL}}/clientes/?celular={{PHONE_9DIGITS}}&limit=5",
              "host": ["{{WISPHUB_URL}}"],
              "path": ["clientes", ""],
              "query": [
                { "key": "celular", "value": "{{PHONE_9DIGITS}}" },
                { "key": "limit", "value": "5" }
              ]
            },
            "description": "Buscar cliente por celular SIN prefijo 51 (9 digitos). CAMBIAR PHONE_9DIGITS en las variables."
          }
        },
        {
          "name": "1b. Buscar por celular (con prefijo 51)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "const results = r.results || (Array.isArray(r) ? r : []);",
                  "console.log('Resultados con prefijo 51:', results.length);",
                  "if (results.length > 0) {",
                  "  const c = results[0];",
                  "  console.log('ID:', c.id_servicio || c.id, '| Nombre:', c.nombre, '| Celular:', c.celular);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Api-Key {{WISPHUB_TOKEN}}" }],
            "url": {
              "raw": "{{WISPHUB_URL}}/clientes/?celular={{PHONE_AUDIT}}&limit=5",
              "host": ["{{WISPHUB_URL}}"],
              "path": ["clientes", ""],
              "query": [
